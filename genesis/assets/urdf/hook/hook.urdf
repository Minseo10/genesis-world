<?xml version="1.0"?>
<robot name="simple_hook_robot">

  <link name="hook_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>

    <!-- 긴 가로 부분 visual -->
    <visual>
      <origin xyz="0 0 0" rpy="1.57 0 0"/>
      <geometry>
        <box size="0.20 0.016 0.016"/>
      </geometry>
      <material name="dark_brown">
        <color rgba="0.4 0.26 0.13 1"/>
      </material>
    </visual>

    <!-- 아래로 꺾인 짧은 부분 visual -->
    <visual>
      <origin xyz="0.108 0.0525 0" rpy="1.57 0 0"/>
      <geometry>
        <box size="0.016 0.016 0.12"/>
      </geometry>
      <material name="dark_brown">
        <color rgba="0.4 0.26 0.13 1"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="1.57 0 0"/>
      <geometry>
        <box size="0.20 0.016 0.016"/>
      </geometry>
    </collision>

    <collision>
      <origin xyz="0.108 0.0525 0" rpy="1.57 0 0"/>
      <geometry>
        <box size="0.016 0.016 0.12"/>
      </geometry>
    </collision>

  </link>
</robot>

